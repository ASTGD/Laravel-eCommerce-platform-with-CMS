{
    "name": "platform/commerce-core",
    "version": "0.1.0",
    "description": "Commerce integration layer for the reusable platform",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3"
    },
    "autoload": {
        "psr-4": {
            "Platform\\CommerceCore\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Platform\\CommerceCore\\Providers\\CommerceCoreServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
